            deckItems.forEach(item => {
                const card = document.createElement('div');
                card.className = 'organism-card bg-slate-50 border-2 border-slate-100 p-4 rounded-2xl text-center hover:border-blue-300 hover:shadow-md flex flex-col items-center justify-between';
