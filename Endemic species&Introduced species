            fb.className = `flex items-center gap-3 px-8 py-3 rounded-full shadow-lg border feedback-pop ${isSuccess ? 'bg-green-600 border-green-700' : 'bg-red-600 border-red-700'}`;
            fbText.innerText = text;
            fbIcon.innerHTML = isSuccess ? '<i data-lucide="check-circle-2" class="w-6 h-6 text-white"></i>' : '<i data-lucide="x-circle" class="w-6 h-6 text-white"></i>';
            
            fb.classList.remove('hidden');
            lucide.createIcons();
            
            setTimeout(() => fb.classList.add('hidden'), 2000);
        }

        function checkRoundEnd() {
            if (deckItems.length === 0) {
                const deckContainer = document.getElementById('organisms-deck');
                deckContainer.classList.add('hidden');
                
                const complete = document.getElementById('round-complete');
                const title = document.getElementById('complete-title');
                const desc = document.getElementById('complete-desc');
                const btn = document.getElementById('next-btn');
                
                complete.classList.remove('hidden');
                
                if (currentRound === 1) {
                    title.innerText = "第一回合完成！";
                    desc.innerText = "你已經成功分類了第一批生物。準備好迎接下一批挑戰嗎？";
                    btn.innerText = "進入第二回合";
                    btn.onclick = startSecondRound;
                } else {
                    title.innerText = "全部挑戰成功！";
                    desc.innerText = `恭喜你！你的最終得分是 ${score} 分。你對台灣生物的分類非常熟悉喔！`;
                    btn.innerText = "重新開始遊戲";
                    btn.onclick = resetGame;
                }
            }
        }

        function startSecondRound() {
            initRound(2);
        }

        function resetGame() {
            score = 0;
            document.getElementById('score').innerText = 0;
            initRound(1);
        }

        // Global click to deselect
        document.body.onclick = () => {
            if (selectedId) {
                document.getElementById(`card-${selectedId}`)?.classList.remove('selected');
                selectedId = null;
            }
        };

        // Start initial round
        window.onload = () => initRound(1);

    </script>
</body>
</html>
