<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>台灣生物分類挑戰賽</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&display=swap');
        
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-color: #f1f5f9;
        }

        .drop-zone {
            transition: all 0.3s ease;
        }

        .drop-zone.drag-over {
            transform: scale(1.02);
            border-color: #fbbf24;
            background-color: #fffbeb;
        }

        .organism-card {
            cursor: grab;
            transition: all 0.2s ease;
        }

        .organism-card:active {
            cursor: grabbing;
        }

        .organism-card.selected {
            border-color: #fbbf24;
            background-color: #fffbeb;
            transform: scale(1.05);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .feedback-pop {
            animation: pop 0.4s ease-out;
        }

        @keyframes pop {
            0% { transform: scale(0.5); opacity: 0; }
            70% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }

        .hidden-item {
            display: none;
        }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8">

    <div class="max-w-5xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-6 bg-white p-6 rounded-3xl shadow-sm border border-slate-100">
            <div class="flex items-center gap-6">
                <!-- 遊戲 Logo -->
                <img src="image_0.png" alt="台灣生物分類挑戰賽 Logo" class="w-20 h-20 md:w-24 md:h-24">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800">
                        台灣生物分類挑戰賽
                    </h1>
                    <p id="round-indicator" class="text-blue-600 font-bold text-lg">第 1 / 2 回合</p>
                    <p class="text-slate-600">請將下方的生物拖曳到正確的分類框中</p>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="bg-white px-6 py-2 rounded-full shadow-sm border border-slate-200 font-bold text-blue-600 text-xl">
                    得分：<span id="score">0</span>
                </div>
                <button onclick="resetGame()" class="flex items-center gap-2 bg-white hover:bg-slate-50 text-slate-700 px-4 py-2 rounded-full shadow-sm border border-slate-200 transition-all">
                    <i data-lucide="refresh-cw" class="w-4 h-4"></i> 重新開始
                </button>
            </div>
        </div>

        <!-- Categories -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
            <!-- Endemic Box -->
            <div id="endemic-zone" class="drop-zone min-h-[250px] rounded-3xl border-2 border-dashed border-blue-400 bg-blue-50 p-6 flex flex-col relative" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'endemic')" onclick="handleZoneClick('endemic')">
                <div class="flex items-center justify-center gap-3 mb-6 font-bold text-2xl text-blue-700">
                    <i data-lucide="map-pin" class="w-8 h-8"></i> 特有種
                </div>
                <div id="endemic-list" class="flex flex-wrap gap-3 content-start flex-grow"></div>
                <div class="empty-hint absolute inset-0 flex items-center justify-center text-slate-400 pointer-events-none opacity-50">
                    拖入特有生物卡片
                </div>
            </div>

            <!-- Invasive Box -->
            <div id="invasive-zone" class="drop-zone min-h-[250px] rounded-3xl border-2 border-dashed border-red-400 bg-red-50 p-6 flex flex-col relative" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'invasive')" onclick="handleZoneClick('invasive')">
                <div class="flex items-center justify-center gap-3 mb-6 font-bold text-2xl text-red-700">
                    <i data-lucide="alert-triangle" class="w-8 h-8"></i> 外來種
                </div>
                <div id="invasive-list" class="flex flex-wrap gap-3 content-start flex-grow"></div>
                <div class="empty-hint absolute inset-0 flex items-center justify-center text-slate-400 pointer-events-none opacity-50">
                    拖入外來生物卡片
                </div>
            </div>
        </div>

        <!-- Feedback UI -->
        <div class="h-16 flex justify-center mb-6">
            <div id="feedback-msg" class="hidden flex items-center gap-3 px-8 py-3 rounded-full shadow-lg border feedback-pop">
                <span id="feedback-icon"></span>
                <span id="feedback-text" class="font-bold text-lg text-white"></span>
            </div>
        </div>

        <!-- Organisms Deck -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-200">
            <h2 class="text-xl font-semibold text-slate-700 mb-6">待分類生物</h2>
            <div id="organisms-deck" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
                <!-- Cards will be injected here -->
            </div>

            <!-- Round Complete -->
            <div id="round-complete" class="hidden py-12 text-center flex flex-col items-center gap-4">
                <div class="bg-yellow-100 p-8 rounded-full mb-4">
                    <i data-lucide="trophy" class="w-20 h-20 text-yellow-600"></i>
                </div>
                <h3 id="complete-title" class="text-4xl font-bold text-slate-800">第一回合完成！</h3>
                <p id="complete-desc" class="text-xl text-slate-600">準備好挑戰下一批生物了嗎？</p>
                <button id="next-btn" onclick="startSecondRound()" class="mt-6 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-10 rounded-full shadow-lg transition-transform hover:scale-105">
                    進入第二回合
                </button>
            </div>
        </div>

        <!-- Footer Info -->
        <div class="mt-12 flex flex-col md:flex-row gap-6 text-sm text-slate-500">
            <div class="flex-1 bg-white p-4 rounded-xl border border-slate-100">
                <strong class="text-blue-600 block mb-1">特有種 (Endemic Species)：</strong> 
                僅在台灣自然分布的「獨立物種」。本次挑戰已遵循嚴謹的生物學分類，嚴格排除了非特有種與「特有亞種」(如台灣黑熊)。
            </div>
            <div class="flex-1 bg-white p-4 rounded-xl border border-slate-100">
                <strong class="text-red-600 block mb-1">外來種 (Invasive Species)：</strong> 
                人為引進非原生於台灣的生物，可能危害本土生態平衡。
            </div>
        </div>
    </div>

