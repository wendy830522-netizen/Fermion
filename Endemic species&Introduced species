                let iconHtml;
                if (item.icon.endsWith('.jpg')) {
                    iconHtml = `<img src="${item.icon}" alt="${item.name}" class="w-16 h-16 object-cover rounded-lg mb-2 shadow-sm">`;
                } else {
                    iconHtml = `<div class="flex justify-center mb-2 text-4xl">${item.icon}</div>`;
                }

                card.innerHTML = `
                    ${iconHtml}
                    <div class="font-bold text-slate-800">${item.name}</div>
                `;
                
                // Drag Events
                card.ondragstart = (e) => {
                    e.dataTransfer.setData('text/plain', item.id);
                    card.classList.add('opacity-50');
                };
                card.ondragend = () => card.classList.remove('opacity-50');
                
                // Click Event (Mobile/Tab)
                card.onclick = (e) => {
                    e.stopPropagation();
                    if (selectedId === item.id) {
                        selectedId = null;
                        card.classList.remove('selected');
                    } else {
                        if (selectedId) document.getElementById(`card-${selectedId}`)?.classList.remove('selected');
                        selectedId = item.id;
                        card.classList.add('selected');
                    }
                };

                deckEl.appendChild(card);
            });
